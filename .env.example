# Telegram Bot API
TELEGRAM_TOKEN=''

# Kyivstar API credentials
CLIENT_ID=''
CLIENT_SECRET=''

# SMS settings
SENDER_NAME=messagedesk
USE_SANDBOX=true
MAX_SMS_TEXT_LENGTH=255
MAX_SMS_SEGMENTS=6

# Telethon listener (Telegram MTProto)
# Get API ID/hash: https://my.telegram.org
TELETHON_API_ID=0
TELETHON_API_HASH=''
TELETHON_SESSION_NAME=telethon_sms_listener

# Comma-separated list of public usernames OR chat IDs (e.g. @brand_channel,-1001234567890)
TELETHON_WATCH_CHATS=

# Comma-separated keywords to trigger alert, case-insensitive
TELETHON_KEYWORDS=знижка,brand

# Comma-separated recipients for SMS alerts
TELETHON_ALERT_PHONES=380971234567

# Do not send duplicate alerts with same chat+keyword+text within N seconds
TELETHON_DEDUPE_SECONDS=1800

# Hard cap for generated SMS alert text length (40..255)
TELETHON_MAX_SMS_CHARS=180
